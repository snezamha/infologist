{
  "name": "infologist",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.12.0"
  },
  "scripts": {
    "dev": "node scripts/modules/sync-module-paths.mjs && next dev",
    "dev:webpack": "node scripts/modules/sync-module-paths.mjs && next dev --webpack",
    "build": "node scripts/modules/sync-module-paths.mjs && node scripts/modules/validate-modules.mjs && next build && node scripts/modules/copy-modules.mjs",
    "start": "next start",
    "ui:check": "node scripts/qa/ui-check.mjs",
    "module:create": "node --experimental-strip-types scripts/modules/create-module.ts",
    "module:delete": "node --experimental-strip-types scripts/modules/delete-module.ts --key",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test:modules && npm run validate:i18n && npx prisma validate",
    "validate:i18n": "node --experimental-strip-types scripts/i18n/validate-translations.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test:modules": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/features/modules/_core/semver.test.mts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "node scripts/modules/sync-module-paths.mjs && node scripts/generate-prisma.mjs && husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@base-ui/react": "^1.5.0",
    "@clerk/nextjs": "^7.5.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@puckeditor/core": "^0.21.3",
    "@radix-ui/react-direction": "^1.1.1",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.17",
    "isomorphic-dompurify": "^3.18.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-image-crop": "^11.0.10",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "slugify": "^1.6.9",
    "tailwind-merge": "^3.6.0",
    "ua-parser-js": "^2.0.10",
    "zod": "^4.4.3",
    "@headlessui/react": "^2.2.10",
    "@react-pdf/renderer": "^4.5.1",
    "@react-pdf/types": "^2.11.1",
    "date-fns": "^4.4.0",
    "pdfjs-dist": "^5.7.284"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "@prisma/dev": {
      "@hono/node-server": "^1.19.13"
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "postgres": "^3.4.9",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
